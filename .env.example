# ─── Local development ────────────────────────────────────────
# Copy this file to .env and fill in the values
# For production, set these via your deployment process (never commit .env)

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=restaurant_pos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_pos

# ── Auth (generate secrets with: openssl rand -base64 48) ─────
JWT_SECRET=change-this-to-a-random-secret-in-production-min32
JWT_REFRESH_SECRET=change-this-to-another-random-secret-min32chars

# ── Backend ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Without this, verification links are logged to console (dev mode)
APP_URL=http://localhost:5173

# ── Production only ───────────────────────────────────────────
# DOMAIN=yourdomain.com
